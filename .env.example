DEBUG=True

# For deploy configure the variables: "DB_USER" "DB_PASSWORD" "DB_HOST" "DB_PORT" "DB_NAME"
DATABASE_URL="sqlite:///./database.db"

ALLOWED_ORIGINS=https://localhost:3000,https://localhost:5173

SECURITY_SECRET_KEY="SECRET"
SECURITY_ALGORITHM="HS256"
SECURITY_TOKEN_EXPIRATION=30
POKEMONTCG_IO_API_KEY=""

#Email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

MAIL_FROM=support@brickei.com.br
MAIL_FROM_NAME=Brickei

FRONTEND_URL="localhost"

ADMIN_EMAIL="admin@brickei.com.br"
ADMIN_SENHA="troque-esta-senha"

# Domínio raiz do SaaS (usado pra resolver subdomínio de loja e pro Domain
# do cookie de sessão, ver docs/tcc/MULTI_TENANCY.md). Em produção (DEBUG=
# False) precisa ser o domínio real, ex.: ROOT_DOMAIN=brickei.com.br — o
# app recusa subir com "localhost"/"127.0.0.1"/"localtest.me" aqui fora de
# DEBUG.
#
# Pra testar multi-tenancy por subdomínio localmente, use localtest.me em
# vez de localhost: browsers não compartilham cookie (Domain=.localhost)
# entre subdomínios de "localhost" (não tem uma "registrable domain" de
# verdade por trás), então o login numa loja em {slug}.localhost nunca
# fica autenticado. localtest.me é um domínio público real, mantido só
# pra isso, cujo próprio nome e todos os subdomínios resolvem pra
# 127.0.0.1 — como tem uma registrable domain de verdade, o Domain=
# .localtest.me funciona igual ao Domain=.brickei.com.br de produção.
ROOT_DOMAIN=localtest.me